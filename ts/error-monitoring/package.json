{
  "name": "@evinvest/error-monitoring",
  "version": "0.1.0",
  "description": "Vendor-neutral error-monitoring toolkit: a tiny injectable ErrorSink core plus Sentry adapters for React, Node/Edge, and Next.js. Mirrors the error_monitoring Cargo feature.",
  "license": "BlueOak-1.0.0",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EV-invest/lib.git",
    "directory": "ts/error-monitoring"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.js"
    }
  },
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.core.json --noEmit",
    "prepare": "npm run clean && tsup"
  },
  "peerDependencies": {
    "@sentry/nextjs": "^10.56.0",
    "@sentry/node": "^10.56.0",
    "@sentry/react": "^10.56.0",
    "next": "^14 || ^15 || ^16",
    "react": "^18 || ^19"
  },
  "peerDependenciesMeta": {
    "@sentry/nextjs": {
      "optional": true
    },
    "@sentry/node": {
      "optional": true
    },
    "@sentry/react": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@sentry/nextjs": "^10.56.0",
    "@sentry/node": "^10.56.0",
    "@sentry/react": "^10.56.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^25.0.1",
    "next": "^16",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
